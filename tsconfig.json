{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@fivemtotal/shared": ["packages/shared/src"],
      "@fivemtotal/shared/*": ["packages/shared/src/*"],
      "@fivemtotal/db": ["packages/db/src"],
      "@fivemtotal/db/*": ["packages/db/src/*"]
    },
    "resolveJsonModule": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true
  },
  "exclude": ["node_modules", "dist"]
}
